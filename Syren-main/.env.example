# --- Syren Security Configuration ---
# Thresholds for the Semantic Sentry (0.0 to 1.0)
RISK_THRESHOLD_LOW=0.4
RISK_THRESHOLD_HIGH=0.7

# --- LLM Provider (Groq) ---
# Get your key at https://console.groq.com/keys
LLM_PROVIDER_API_KEY=your_groq_api_key_here

# API Endpoints
PRODUCTION_LLM_URL=https://api.groq.com/openai/v1/chat/completions
CANARY_LLM_URL=https://api.groq.com/openai/v1/chat/completions

# Model IDs
# Recommended: llama3-8b-8192 or llama3-70b-8192
PRODUCTION_MODEL=llama3-8b-8192
CANARY_MODEL=llama3-8b-8192

# --- Infrastructure & Logging ---
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.jsonl